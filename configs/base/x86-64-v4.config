# x86-64-v4 — AVX-512F, AVX-512BW, AVX-512CD, AVX-512DQ, AVX-512VL
# Equivalent to XanMod's CONFIGS/xanmod/gcc/config_x86-64-v4
# Suitable for Intel Skylake-X (2017+) and AMD Zen 4 (2022+).
# Use only if your CPU supports AVX-512; will SIGILL on older hardware.

CONFIG_GENERIC_CPU4=y
CONFIG_X86_64=y
CONFIG_X86_FEATURE_NAMES=y

CONFIG_LOCALVERSION="-xanmod1"
CONFIG_LOCALVERSION_AUTO=n

CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
