# x86-64-v2 — SSE4.2, POPCNT, CX16, LAHF
# Equivalent to XanMod's CONFIGS/xanmod/gcc/config_x86-64-v2
# Suitable for Intel Nehalem (2008+) and AMD Bulldozer (2011+).

CONFIG_GENERIC_CPU2=y
CONFIG_X86_64=y
CONFIG_X86_FEATURE_NAMES=y

CONFIG_LOCALVERSION="-xanmod1"
CONFIG_LOCALVERSION_AUTO=n

CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
