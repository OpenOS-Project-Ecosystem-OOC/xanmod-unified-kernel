# x86-64-v3 — AVX, AVX2, BMI1, BMI2, FMA, MOVBE, XSAVE
# Equivalent to XanMod's CONFIGS/xanmod/gcc/config_x86-64-v3
# Suitable for Intel Haswell (2013+) and AMD Excavator (2015+).
# This is the recommended level for most modern desktops and laptops.

CONFIG_GENERIC_CPU3=y
CONFIG_X86_64=y
CONFIG_X86_FEATURE_NAMES=y

CONFIG_LOCALVERSION="-xanmod1"
CONFIG_LOCALVERSION_AUTO=n

CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
