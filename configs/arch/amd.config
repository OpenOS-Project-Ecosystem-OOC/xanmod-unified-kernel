# arch/amd.config — AMD CPU tuning fragment
# Source: zakuradev/kernel-configuration
#
# Disables most Intel-specific features to reduce image size and avoid
# unnecessary code paths on AMD-only systems.
# Apply with: VENDOR=amd

# Disable Intel P-state driver (use ACPI CPUfreq or amd-pstate instead)
# CONFIG_X86_INTEL_PSTATE is not set

# Disable Intel uncore PMU
# CONFIG_INTEL_UNCORE_FREQ_CONTROL is not set

# Disable Intel SGX
# CONFIG_X86_SGX is not set

# Disable Intel Speed Select
# CONFIG_INTEL_SPEED_SELECT_INTERFACE is not set

# Disable Intel PMC
# CONFIG_MFD_INTEL_PMC_BXT is not set

# AMD P-state driver
CONFIG_X86_AMD_PSTATE=y
CONFIG_X86_AMD_PSTATE_UT=n

# AMD IOMMU
CONFIG_AMD_IOMMU=y
CONFIG_AMD_IOMMU_V2=y

# AMD memory encryption
CONFIG_AMD_MEM_ENCRYPT=y
CONFIG_AMD_MEM_ENCRYPT_ACTIVE_BY_DEFAULT=n
