# arch/intel.config — Intel CPU tuning fragment
#
# Enables Intel-specific features. Apply with: VENDOR=intel

# Intel P-state
CONFIG_X86_INTEL_PSTATE=y

# Intel SGX
CONFIG_X86_SGX=y

# Intel Speed Select
CONFIG_INTEL_SPEED_SELECT_INTERFACE=y

# Intel uncore
CONFIG_INTEL_UNCORE_FREQ_CONTROL=y

# Intel IOMMU
CONFIG_INTEL_IOMMU=y
CONFIG_INTEL_IOMMU_DEFAULT_ON=n
CONFIG_INTEL_IOMMU_SVM=y

# Intel TDX (Trust Domain Extensions)
CONFIG_INTEL_TDX_HOST=y
