# hardware/asus-rog.config — ASUS ROG platform Kconfig fragment
# Source: arglebargle-arch/xanmod-rog-PKGBUILD
#
# Applied when ENABLE_ROG=1 or profile=rog.

# ASUS WMI platform driver
CONFIG_ASUS_WMI=y
CONFIG_ASUS_NB_WMI=y

# HID ASUS (keyboard, touchpad, ROG-specific HID)
CONFIG_HID_ASUS=y

# ACPI battery (fresh state reads)
CONFIG_ACPI_BATTERY=y

# Fan control via hwmon
CONFIG_SENSORS_ASUS_WMI_EC=y
CONFIG_SENSORS_ASUS_EC=y

# Tablet mode / accelerometer
CONFIG_IIO=y
CONFIG_IIO_BUFFER=y
CONFIG_IIO_TRIGGERED_BUFFER=y
CONFIG_KXSD9=m
CONFIG_BMC150_ACCEL=m

# Suspend: S0ix (modern standby) support
# Requires s0ix patch to be applied (patches/hardware/asus-rog/)
CONFIG_ACPI_EC_DEBUGFS=y
CONFIG_PM_DEBUG=n

# Wireless: MT7921 (common in ROG laptops)
CONFIG_MT7921E=m
CONFIG_MT7921S=m
CONFIG_MT7921U=m
CONFIG_MT76_CONNAC_LIB=m
