# features/rt.config — PREEMPT_RT real-time fragment
# Applied automatically when BRANCH=RT. Can also be applied manually.

# Full preemption
CONFIG_PREEMPT_RT=y
# CONFIG_PREEMPT_NONE is not set
# CONFIG_PREEMPT_VOLUNTARY is not set
# CONFIG_PREEMPT is not set

# High-resolution timers required for RT
CONFIG_HIGH_RES_TIMERS=y
CONFIG_HZ_1000=y
CONFIG_HZ=1000

# IRQ threading
CONFIG_IRQ_FORCED_THREADING=y

# Disable features incompatible with RT
# CONFIG_PREEMPT_RCU is not set
CONFIG_RCU_BOOST=y
CONFIG_RCU_BOOST_DELAY=500
