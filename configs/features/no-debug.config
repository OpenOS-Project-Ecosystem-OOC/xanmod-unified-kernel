# features/no-debug.config — disable debug/tracing overhead
# Source: zakuradev/kernel-configuration
#
# Reduces kernel image size and eliminates runtime overhead from debug
# infrastructure. Do not apply if you need kernel debugging or profiling.

# Kernel hacking
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_DEBUG_INFO is not set
# CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT is not set
# CONFIG_DEBUG_INFO_NONE is not set
CONFIG_DEBUG_INFO_NONE=y

# NUMA emulation (only useful for testing NUMA on non-NUMA hardware)
# CONFIG_NUMA_EMU is not set

# Tracers
# CONFIG_FTRACE is not set
# CONFIG_KPROBES is not set
# CONFIG_UPROBE_EVENTS is not set

# Lock debugging
# CONFIG_PROVE_LOCKING is not set
# CONFIG_LOCK_STAT is not set
# CONFIG_DEBUG_LOCKDEP is not set

# Memory debugging
# CONFIG_KASAN is not set
# CONFIG_UBSAN is not set
# CONFIG_KCSAN is not set

# Panic behavior
CONFIG_PANIC_ON_OOPS=n
CONFIG_PANIC_TIMEOUT=0
