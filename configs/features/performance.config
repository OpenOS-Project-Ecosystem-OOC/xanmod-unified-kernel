# features/performance.config — performance-oriented defaults
#
# Sets scheduler, timer, and governor defaults for throughput/latency.
# Applied by default for non-RT builds; can be overridden by user config.

# Tick rate
CONFIG_HZ_1000=y
CONFIG_HZ=1000

# Full tickless (dynticks) — reduces timer interrupts on idle CPUs
CONFIG_NO_HZ_FULL=y
CONFIG_RCU_NOCB_CPU=y

# Preemption model: voluntary (balance between throughput and latency)
# For desktop/gaming use PREEMPT instead.
CONFIG_PREEMPT_VOLUNTARY=y

# CPU frequency governor default: performance
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
# CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL is not set
# CONFIG_CPU_FREQ_DEFAULT_GOV_ONDEMAND is not set

# I/O scheduler: mq-deadline as default (good general-purpose choice)
CONFIG_DEFAULT_IOSCHED="mq-deadline"
CONFIG_MQ_IOSCHED_DEADLINE=y
CONFIG_MQ_IOSCHED_KYBER=y
CONFIG_IOSCHED_BFQ=y

# BBR TCP congestion control
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"

# nftables (XanMod default)
CONFIG_NF_TABLES=y
CONFIG_NFT_COUNTER=y
CONFIG_NFT_LOG=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_REDIR=y
CONFIG_NFT_NAT=y
